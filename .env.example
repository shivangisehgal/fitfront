# =============================================================================
# FitFront — Environment configuration
# =============================================================================
#
# Quick start (local demo — chat only, no phone/SMS):
#   cp .env.example .env
#   docker compose up -d postgres
#   python3 -m venv venv && source venv/bin/activate
#   pip install -r requirements.txt && python3 seed_data.py
#   python3 -m uvicorn backend.main:app --reload --port 8000
#   cd frontend && npm install && npm run dev
#
# Full stack (real SMS, calendar, voice): see docs/FULL_STACK_SETUP.md
#   Set DEMO_MODE=false, LOCAL_CHAT_MODE=false, fill Twilio/Google/Bolna,
#   run ./start.sh for a public tunnel URL.
#
# =============================================================================


# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Docker Compose exposes Postgres on host port 5433 (see docker-compose.yml).
# Use 5432 only if you run Postgres directly on your machine (not via Docker).
DATABASE_URL=postgresql+asyncpg://scheduler_user:scheduler_pass@localhost:5433/scheduler_ai

# ── Admin login (created automatically on first backend startup) ───────────────
ADMIN_EMAIL=admin@fitfront.local
ADMIN_PASSWORD=changeme

# ── App ──────────────────────────────────────────────────────────────────────
SERVER_BASE_URL=http://localhost:8000
OFFICE_TIMEZONE=America/Chicago
OFFICE_NAME=FitFront

# Local demo: simulated SMS/calendar, browser chat at /chat (no phone needed)
DEMO_MODE=true
LOCAL_CHAT_MODE=true

# ── LLM — pick ONE provider ──────────────────────────────────────────────────
# Option A: Ollama (local, free — best for chat-only dev)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# Option B: Google Gemini (cloud — required for voice if Ollama isn't public)
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# ── Google Calendar OAuth (platform-wide — one app, each studio connects) ────
# Create at https://console.cloud.google.com → OAuth client (Web application)
# Redirect URI: http://localhost:8000/api/integrations/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/integrations/google/callback

# ── Twilio SMS (platform-wide credentials; admin assigns per-tenant numbers) ─
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
FEATURE_TWILIO_ENABLED=true

# ── Bolna AI voice (platform admin can also set via Manage Tenants → Platform Settings)
BOLNA_API_KEY=
BOLNA_AGENT_ID=

# Escalation: SMS alert + optional live transfer when caller asks for a human
ESCALATION_PHONE_NUMBER=
ESCALATION_TRANSFER_NUMBER=

# JWT secret — change before production
# JWT_SECRET=


# =============================================================================
# FULL STACK — uncomment and adjust for real SMS, calendar sync, and voice
# =============================================================================
# Requires a public URL for Twilio/Bolna webhooks. Run ./start.sh (localtunnel)
# or ngrok, then paste the https URL into SERVER_BASE_URL and Twilio/Bolna dashboards.
#
# DEMO_MODE=false
# LOCAL_CHAT_MODE=false
# SERVER_BASE_URL=https://your-subdomain.loca.lt
#
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.0-flash
#
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
#
# GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
#
# BOLNA_API_KEY=your-bolna-api-key
# BOLNA_AGENT_ID=your-bolna-agent-uuid
#
# Integration webhook URLs (replace with your SERVER_BASE_URL):
#   Twilio SMS inbound:  {SERVER_BASE_URL}/webhook/sms
#   Bolna custom LLM:    {SERVER_BASE_URL}/api/llm
#   Bolna caller lookup: {SERVER_BASE_URL}/api/bolna/caller-lookup
#   Bolna call webhook:  {SERVER_BASE_URL}/api/bolna/webhook
#
# After starting backend:
#   1. Register a studio → log in as admin → approve tenant
#   2. Admin → tenant → Integrations: assign Twilio phone number, enable agent
#   3. Admin → Platform Settings: save Bolna API key + agent ID
#   4. Studio owner → AI Agent → Connect Google Calendar
#   5. Configure Bolna agent LLM URL → {SERVER_BASE_URL}/api/llm
#
# Seeded demo tenant (Iron & Ivy) has demo_mode=true — register a fresh studio
# or run: UPDATE tenants SET demo_mode = false WHERE slug = 'iron-and-ivy-fitness';
